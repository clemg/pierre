# Keep the build context small and the image clean
**/node_modules
**/.next
**/dist
**/.turbo
**/coverage
**/playwright-report
**/test-results

# Benchmark scratch (huge cached patches, logs), never needed in the image
bench/.cache
bench/*.log

# Git / editor / OS
.git
.gitignore
**/.DS_Store
**/*.log
npm-debug.log*

# Local env files (set real env in Dokploy)
**/.env
**/.env.*
!**/.env.example
