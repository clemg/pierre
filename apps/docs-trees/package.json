{
  "name": "@pierre/docs-trees",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun run build:deps && bun run generate-llms-txt && bun run build:next",
    "build:next": "next build",
    "build:deps": "bun run build:deps:diffs && bun run build:deps:trees && bun run build:deps:docs-shared",
    "build:deps:diffs": "output=$(cd ../../packages/diffs && bun run build 2>&1) && echo '[diffs] Successfully cleaned and built.' || (echo \"$output\" >&2 && exit 1)",
    "build:deps:trees": "output=$(cd ../../packages/trees && bun run build 2>&1) && echo '[trees] Successfully cleaned and built.' || (echo \"$output\" >&2 && exit 1)",
    "build:deps:docs-shared": "output=$(cd ../../packages/docs-shared && bun run build 2>&1) && echo '[docs-shared] Successfully cleaned and built.' || (echo \"$output\" >&2 && exit 1)",
    "dev": "export PORT=$((${PIERRE_PORT_OFFSET:-0} + 3691)) && bash ../../scripts/run-dev.sh \"$PORT\" -- bun run _dev",
    "_dev": "bun run build:deps && bun concurrently \"bun run dev:deps:diffs\" \"bun run dev:deps:trees\" \"bun run dev:deps:docs-shared\" \"bun run dev:next\" --names \"diffs,trees,shared,docs\" --prefix-colors \"blue,green,cyan,purple\"",
    "dev:next": "next dev",
    "dev:deps:diffs": "(cd ../../packages/diffs && bun run dev)",
    "dev:deps:trees": "(cd ../../packages/trees && bun run dev)",
    "dev:deps:docs-shared": "(cd ../../packages/docs-shared && bun run dev)",
    "prod": "bun run build && next start",
    "start": "next start",
    "generate-llms-txt": "bun ../../scripts/generate-llms-txt.ts trees",
    "test:e2e": "bun run build:deps && bun run build:next && (bun ./test/e2e/check-playwright-binary.ts || bun run test:e2e:installbinary) && bunx playwright test -c test/e2e/playwright.config.ts",
    "test:e2e:installbinary": "bunx playwright@1.51.1 install chromium",
    "test:e2e:server": "PORT=$((${PIERRE_PORT_OFFSET:-0} + 4175)) bash ../../scripts/run-dev.sh \"$PORT\" -- bun run start",
    "tsc": "bun run build:deps && tsgo --noEmit --pretty"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "catalog:",
    "@pierre/diffs": "workspace:*",
    "@pierre/docs-shared": "workspace:*",
    "@pierre/icons": "catalog:",
    "@pierre/tree-test-data": "workspace:*",
    "@pierre/trees": "workspace:*",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-navigation-menu": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-toggle": "catalog:",
    "@radix-ui/react-toggle-group": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@radix-ui/react-use-controllable-state": "catalog:",
    "@shikijs/transformers": "catalog:",
    "@vscode/web-custom-data": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "hast-util-heading-rank": "catalog:",
    "hast-util-to-string": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "next-mdx-remote": "catalog:",
    "postcss": "catalog:",
    "postcss-import": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "remark-gfm": "catalog:",
    "shadcn": "catalog:",
    "shiki": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "unist-util-visit": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/hast": "catalog:",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "concurrently": "catalog:",
    "typescript": "catalog:"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
