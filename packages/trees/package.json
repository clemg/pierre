{
  "name": "@pierre/trees",
  "version": "0.0.1-beta.4",
  "license": "apache-2.0",
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/components/web-components.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web-components": {
      "types": "./dist/web-components.d.ts",
      "import": "./dist/web-components.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "import": "./dist/ssr/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "benchmark": "bun run benchmark:file-tree-get-item",
    "benchmark:file-tree-get-item": "bun run ./scripts/benchmarkFileTreeGetItem.ts",
    "profile:file-tree": "bun run ./scripts/profileFileTree.ts",
    "dev": "echo 'Watching for changes…' && tsdown --watch --log-level error",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "test:e2e:base": "bun run build && (bun ./test/e2e/check-playwright-binary.ts || bun run test:e2e:installbinary)",
    "test:e2e": "bun run test:e2e:base && bunx playwright test -c test/e2e/playwright.config.ts --grep-invert @diagnostic",
    "test:e2e:sticky-drift": "bun run test:e2e:base && bunx playwright test -c test/e2e/playwright.config.ts test/e2e/file-tree-sticky-context-menu-scroll-drift.pw.ts",
    "test:e2e:installbinary": "bunx playwright@1.51.1 install chromium",
    "test:e2e:server": "vite --config test/e2e/vite.config.ts",
    "tsc": "tsgo --noEmit --pretty",
    "generate-icons": "bun scripts/generate-built-in-icons.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pierre/path-store": "workspace:*",
    "preact": "catalog:",
    "preact-render-to-string": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@pierre/tree-test-data": "workspace:*",
    "@pierre/vscode-icons": "catalog:",
    "@playwright/test": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@types/jsdom": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "catalog:",
    "jsdom": "catalog:",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
