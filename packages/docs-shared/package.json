{
  "name": "@pierre/docs-shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./components/CustomScrollbarCSS": "./src/components/CustomScrollbarCSS.ts",
    "./components/Button.module.css": "./src/components/Button.module.css",
    "./components/*": {
      "types": "./src/components/*.tsx",
      "import": "./dist/components/*.js"
    },
    "./components/ui/*": {
      "types": "./src/components/ui/*.tsx",
      "import": "./dist/components/ui/*.js"
    },
    "./docs/types": {
      "types": "./src/docs/types.ts",
      "import": "./dist/docs/types.js"
    },
    "./docs/*": {
      "types": "./src/docs/*.tsx",
      "import": "./dist/docs/*.js"
    },
    "./lib/mdx": {
      "types": "./src/lib/mdx.tsx",
      "import": "./dist/lib/mdx.js"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./dist/lib/*.js"
    },
    "./config/products": {
      "types": "./src/config/products.ts",
      "import": "./dist/config/products.js"
    },
    "./site/SiteContext": {
      "types": "./src/site/SiteContext.tsx",
      "import": "./dist/site/SiteContext.js"
    },
    "./layout/RootLayoutShell": {
      "types": "./src/layout/RootLayoutShell.tsx",
      "import": "./dist/layout/RootLayoutShell.js"
    },
    "./layout/buildDocsMetadata": {
      "types": "./src/layout/buildDocsMetadata.ts",
      "import": "./dist/layout/buildDocsMetadata.js"
    },
    "./layout/themeBootstrap": {
      "types": "./src/layout/themeBootstrap.ts",
      "import": "./dist/layout/themeBootstrap.js"
    },
    "./layout/viewport": {
      "types": "./src/layout/viewport.ts",
      "import": "./dist/layout/viewport.js"
    },
    "./layout/worktreeTitlePrefix": {
      "types": "./src/layout/worktreeTitlePrefix.ts",
      "import": "./dist/layout/worktreeTitlePrefix.js"
    },
    "./styles/globals.css": "./src/styles/globals.css",
    "./styles/prose.css": "./src/styles/prose.css",
    "./testing/*": "./src/testing/*.ts",
    "./postcss": "./postcss.config.mjs"
  },
  "scripts": {
    "build": "tsdown && bun run build:assets",
    "build:assets": "mkdir -p dist/components && cp src/components/Button.module.css dist/components/Button.module.css",
    "dev": "bun run build:assets && echo 'Watching for changes…' && tsdown --watch --log-level error",
    "tsc": "tsgo --noEmit --pretty"
  },
  "dependencies": {
    "@pierre/diffs": "workspace:*",
    "@pierre/icons": "catalog:",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-navigation-menu": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-toggle": "catalog:",
    "@radix-ui/react-toggle-group": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@radix-ui/react-use-controllable-state": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "hast-util-heading-rank": "catalog:",
    "hast-util-to-string": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "next-mdx-remote": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "remark-gfm": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "unist-util-visit": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@types/hast": "catalog:",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
